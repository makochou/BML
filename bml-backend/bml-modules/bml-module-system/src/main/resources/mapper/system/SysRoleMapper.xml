<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bml.module.system.mapper.SysRoleMapper">

    <resultMap type="com.bml.module.system.entity.SysRole" id="SysRoleResult">
        <id     property="id"             column="id"               />
        <result property="roleName"       column="role_name"        />
        <result property="roleCode"       column="role_code"        />
        <result property="sort"           column="sort"             />
        <result property="dataScope"      column="data_scope"       />
        <result property="status"         column="status"           />
        <result property="remark"         column="remark"           />
        <result property="createTime"     column="create_time"      />
    </resultMap>

    <sql id="selectRoleVo">
        select r.id, r.role_name, r.role_code, r.sort, r.data_scope, r.status, r.create_time, r.remark 
        from sys_role r
    </sql>

    <select id="selectRolesByUserId" parameterType="Long" resultMap="SysRoleResult">
        <include refid="selectRoleVo"/>
        left join sys_user_role ur on ur.role_id = r.id
        where ur.user_id = #{userId} and r.deleted = 0
    </select>
    
</mapper>
