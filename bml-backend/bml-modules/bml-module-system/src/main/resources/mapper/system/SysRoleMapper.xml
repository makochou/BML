<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bml.module.system.mapper.SysRoleMapper">

    <!-- 角色结果映射 -->
    <resultMap type="com.bml.module.system.entity.SysRole" id="SysRoleResult">
        <id     property="id"             column="id"               />
        <result property="roleName"       column="role_name"        />
        <result property="roleCode"       column="role_code"        />
        <result property="sort"           column="sort"             />
        <result property="dataScope"      column="data_scope"       />
        <result property="status"         column="status"           />
        <result property="remark"         column="remark"           />
        <result property="createTime"     column="create_time"      />
    </resultMap>

    <!--
        根据用户ID查询角色列表
        关联关系：sys_role -> sys_user_role -> sys_user
        过滤条件：角色未被逻辑删除
    -->
    <select id="selectRolesByUserId" parameterType="Long" resultMap="SysRoleResult">
        SELECT r.id, r.role_name, r.role_code, r.sort,
               r.data_scope, r.status, r.create_time, r.remark
         FROM sys_role r
         INNER JOIN sys_user_role ur ON ur.role_id = r.id
         WHERE ur.user_id = #{userId}
           AND r.deleted = 0
           AND r.status = 1
    </select>
    
</mapper>
