<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
    主题预设 Mapper XML
    - 表：bml_theme_preset
    - JSON 列 profile_admin / profile_business 通过 JacksonTypeHandler
      与 com.bml.module.system.theme.entity.ThemeProfileJson 互转。
    - 自定义查询必须显式声明 ResultMap 才能让 typeHandler 生效；
      BaseMapper 内置 CRUD 由实体 @TableName(autoResultMap=true) 处理，
      不依赖此 ResultMap。
-->
<mapper namespace="com.bml.module.system.theme.mapper.ThemePresetMapper">

    <!-- 主题预设结果映射（含 JSON 列 typeHandler 显式声明） -->
    <resultMap id="ThemePresetResult" type="com.bml.module.system.theme.entity.ThemePreset">
        <id     property="id"          column="id" />
        <result property="name"        column="name" />
        <result property="description" column="description" />
        <result property="isBuiltIn"   column="is_built_in" />
        <result property="isDefault"   column="is_default" />
        <result property="sortOrder"   column="sort_order" />
        <result property="profileAdmin"
                column="profile_admin"
                javaType="com.bml.module.system.theme.entity.ThemeProfileJson"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result property="profileBusiness"
                column="profile_business"
                javaType="com.bml.module.system.theme.entity.ThemeProfileJson"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result property="createdAt"   column="created_at" />
        <result property="updatedAt"   column="updated_at" />
    </resultMap>

    <!-- 公共查询字段 -->
    <sql id="Base_Column_List">
        id, name, description, is_built_in, is_default, sort_order,
        profile_admin, profile_business, created_at, updated_at
    </sql>

    <!--
        查询当前系统默认预设：仅 PRESET_BEST 应满足 is_default = 1；
        使用 LIMIT 1 保护异常数据下的查询稳定性。
    -->
    <select id="selectByDefault" resultMap="ThemePresetResult">
        SELECT
        <include refid="Base_Column_List" />
        FROM bml_theme_preset
        WHERE is_default = 1
        LIMIT 1
    </select>

    <!--
        按排序权重升序返回所有预设；相同 sort_order 时按创建时间升序，
        保证返回顺序稳定，便于前端按序渲染预设网格。
    -->
    <select id="selectAllOrderBySort" resultMap="ThemePresetResult">
        SELECT
        <include refid="Base_Column_List" />
        FROM bml_theme_preset
        ORDER BY sort_order ASC, created_at ASC
    </select>

</mapper>
